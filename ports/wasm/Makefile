# Select the variant to build for:
ifdef VARIANT_DIR
# Custom variant path - remove trailing slash and get the final component of
# the path as the variant name.
VARIANT ?= $(notdir $(VARIANT_DIR:/=))
else
# Default variant is standard (minimal, for Node.js WASI testing).
VARIANT ?= standard
VARIANT_DIR ?= variants/$(VARIANT)
endif

ifeq ($(wildcard $(VARIANT_DIR)/.),)
$(error Invalid VARIANT specified: $(VARIANT_DIR))
endif

# If the build directory is not given, make it reflect the variant name.
BUILD ?= build-$(VARIANT)

include ../../py/mkenv.mk
-include mpconfigport.mk
include $(VARIANT_DIR)/mpconfigvariant.mk

# Use the default frozen manifest, variants may override this.
FROZEN_MANIFEST ?= variants/manifest.py

# Output binary name
PROG ?= circuitpython.wasm

# qstr definitions (must come before including py.mk)
QSTR_DEFS += qstrdefsport.h
QSTR_GLOBAL_DEPENDENCIES += $(VARIANT_DIR)/mpconfigvariant.h

# include py core make definitions
include $(TOP)/py/py.mk
include $(TOP)/extmod/extmod.mk

INC +=  -I.
INC +=  -I$(TOP)
INC += -I$(BUILD)
INC += -Ichassis

# ── wasi-sdk ──
WASI_SDK ?= $(HOME)/.local/bin/wasi-sdk-32.0-x86_64-linux
WASI_SYSROOT = $(WASI_SDK)/share/wasi-sysroot
WASI_CC = $(WASI_SDK)/bin/clang-22
CC  = $(WASI_CC)
LD  = $(WASI_CC)

# compiler settings
CWARN = -Wall
CWARN += -Wextra -Wno-unused-parameter -Wpointer-arith -Wdouble-promotion -Wfloat-conversion -Wno-missing-field-initializers
# wasm32 stream protocol function pointers trigger this
CWARN += -Wno-incompatible-function-pointer-types
CFLAGS += $(INC) $(CWARN) -std=gnu99 -I$(VARIANT_DIR) $(CFLAGS_EXTRA)
CFLAGS += --target=wasm32-wasip1 --sysroot=$(WASI_SYSROOT)
CFLAGS += -D_WASI_EMULATED_PROCESS_CLOCKS

# CircuitPython module flags — must match mpconfigboard.h.
# These are normally generated by circuitpy_mpconfig.mk, but our port
# doesn't include that file, so we define them explicitly.
CFLAGS += -DCIRCUITPY_WARNINGS=1
CFLAGS += -DCIRCUITPY_GETPASS=1
CFLAGS += -DCIRCUITPY_MSGPACK=1
CFLAGS += -DCIRCUITPY_AESIO=1
CFLAGS += -DCIRCUITPY_LOCALE=1
CFLAGS += -DCIRCUITPY_PIXELBUF=1
CFLAGS += -DCIRCUITPY_STORAGE=1

# msgpack: wrap upstream source to rename static read/write (POSIX name clash)
$(BUILD)/shared-module/msgpack/__init__.o: CFLAGS += -include supervisor/msgpack_fixup.h

# WASM exception handling for NLR (setjmp/longjmp)
CFLAGS += -mllvm -wasm-enable-sjlj
CFLAGS += -fwasm-exceptions

# Debugging/Optimization
ifdef DEBUG
COPT ?= -Og
else
COPT ?= -Os
COPT += -DNDEBUG
endif

CFLAGS += $(COPT)

# No stripping or size reporting for WASM binaries (host tools don't understand wasm format)
STRIP =
SIZE = true

# Linker
LDFLAGS += --target=wasm32-wasip1 --sysroot=$(WASI_SYSROOT)
LDFLAGS += -mllvm -wasm-enable-sjlj -fwasm-exceptions
LDFLAGS += -lsetjmp -lwasi-emulated-process-clocks
LDFLAGS += -Wl,--initial-memory=4194304
LDFLAGS += -Wl,-z,stack-size=524288
LDFLAGS += -Wl,--export=malloc -Wl,--export=free
LDFLAGS += $(LDFLAGS_MOD) $(LDFLAGS_EXTRA)

# ── Optional module conditionals ──
# These are kept from the unix port for future adaptation.
# Currently all disabled for initial WASM build.

ifeq ($(MICROPY_USE_READLINE),1)
INC += -I$(TOP)/shared/readline
CFLAGS += -DMICROPY_USE_READLINE=1
SHARED_SRC_C_EXTRA += readline/readline.c
endif

# Source files — core set shared by all variants.
# The WASM supervisor (supervisor/) provides main() and cp_step() exports.
# main.c is the unix port entry point — kept for reference only.
SRC_C += \
	supervisor/supervisor.c \
	supervisor/port.c \
	supervisor/stubs.c \
	supervisor/compile.c \
	supervisor/context.c \
	supervisor/port_memory.c \
	supervisor/vm_yield.c \
	chassis/vm_abort.c \
	chassis/budget.c \
	supervisor/serial.c \
	supervisor/micropython.c \
	supervisor/background_callback.c \
	supervisor/tick.c \
	supervisor/hal.c \
	supervisor/semihosting.c \
	gccollect.c \
	wasi_mphal.c \
	mpthreadport.c \
	modringio.c \
	proxy_c.c \
	objjsproxy.c \
	modjsffi.c \
	shared-module/os/__init__.c \
	supervisor/shared/translate/translate.c \
	$(SRC_MOD) \
	$(wildcard $(VARIANT_DIR)/*.c)

# CircuitPython's time module is in shared-bindings/time + shared-module/time.
# Do NOT include extmod/modtime.c — it registers a conflicting `time` module.
# Set MICROPY_PY_TIME=0 in config to suppress the extmod version.
SRC_C += \
	shared-bindings/time/__init__.c \
	shared-module/time/__init__.c

# Pure-software CircuitPython modules (shared-bindings + shared-module only).
SRC_C += \
	shared-bindings/warnings/__init__.c \
	shared-module/warnings/__init__.c \
	shared-bindings/getpass/__init__.c \
	shared-module/getpass/__init__.c \
	shared-bindings/aesio/__init__.c \
	shared-bindings/aesio/aes.c \
	shared-module/aesio/__init__.c \
	shared-module/aesio/aes.c \
	shared-bindings/locale/__init__.c \
	shared-bindings/adafruit_pixelbuf/__init__.c \
	shared-bindings/adafruit_pixelbuf/PixelBuf.c \
	shared-module/adafruit_pixelbuf/__init__.c \
	shared-module/adafruit_pixelbuf/PixelBuf.c \
	shared-bindings/storage/__init__.c \
	common-hal/storage/__init__.c \
	shared-bindings/msgpack/__init__.c \
	shared-bindings/msgpack/ExtType.c \
	shared-module/msgpack/__init__.c

# Display utility modules — browser variant only (require displayio types).
ifeq ($(VARIANT),browser)
CFLAGS += -DCIRCUITPY_VECTORIO=1
CFLAGS += -DCIRCUITPY_BITMAPTOOLS=1
SRC_C += \
	shared-bindings/vectorio/__init__.c \
	shared-bindings/vectorio/Circle.c \
	shared-bindings/vectorio/Polygon.c \
	shared-bindings/vectorio/Rectangle.c \
	shared-bindings/vectorio/VectorShape.c \
	shared-module/vectorio/__init__.c \
	shared-module/vectorio/Circle.c \
	shared-module/vectorio/Polygon.c \
	shared-module/vectorio/Rectangle.c \
	shared-module/vectorio/VectorShape.c \
	shared-bindings/bitmaptools/__init__.c \
	shared-module/bitmaptools/__init__.c
endif

$(BUILD)/supervisor/shared/translate/translate.o: $(HEADER_BUILD)/qstrdefs.generated.h $(HEADER_BUILD)/compressed_translations.generated.h

SHARED_SRC_C += $(addprefix shared/,\
	runtime/gchelper_generic.c \
	runtime/pyexec.c \
	timeutils/timeutils.c \
	$(SHARED_SRC_C_EXTRA) \
	)

SRC_CXX += \

OBJ = $(PY_O)
OBJ += $(addprefix $(BUILD)/, $(SRC_C:.c=.o))
OBJ += $(addprefix $(BUILD)/, $(SRC_CXX:.cpp=.o))
OBJ += $(addprefix $(BUILD)/, $(SHARED_SRC_C:.c=.o))

# List of sources for qstr extraction
SRC_QSTR += $(SRC_C) $(SRC_CXX) $(SHARED_SRC_C)

ifneq ($(FROZEN_MANIFEST),)
# CIRCUITPY-CHANGE
# To use frozen code create a manifest.py file with a description of files to
# freeze, then invoke make with FROZEN_MANIFEST=manifest.py (be sure to build from scratch).
CFLAGS += -DMICROPY_QSTR_EXTRA_POOL=mp_qstr_frozen_const_pool
CFLAGS += -DMICROPY_MODULE_FROZEN_MPY
CFLAGS += -DMPZ_DIG_SIZE=16 # force 16 bits to work on both 32 and 64 bit archs
CFLAGS += -DMICROPY_MODULE_FROZEN_STR
endif

CXXFLAGS += $(filter-out -Wmissing-prototypes -Wold-style-definition -std=gnu99,$(CFLAGS) $(CXXFLAGS_MOD))

include $(TOP)/py/mkrules.mk

.PHONY: test test-all

NODE ?= $(shell which node)

test: $(BUILD)/$(PROG)
	$(NODE) --experimental-wasi-unstable-preview1 test_node.mjs < /dev/null

test-all: build-standard/circuitpython.wasm build-browser/circuitpython.wasm
	$(NODE) test_standard.mjs
	$(NODE) test_browser.mjs

# ── Abort-resume test ──
# Builds a minimal WASI binary linking MicroPython core + chassis budget/memory
# against a test harness that validates nlr_jump_abort halt/resume.

TEST_ABORT_SRC = chassis/test_abort_resume.c chassis/vm_abort.c \
	chassis/budget.c chassis/port_memory.c
TEST_ABORT_OBJ = $(addprefix $(BUILD)/, $(TEST_ABORT_SRC:.c=.o))

# Need the py core objects but NOT the supervisor (which has its own main)
TEST_ABORT_OBJ += $(PY_O) $(addprefix $(BUILD)/, $(SHARED_SRC_C:.c=.o))

$(BUILD)/chassis/%.o: chassis/%.c | $(BUILD)/chassis
	$(CC) $(CFLAGS) -Ichassis -c -o $@ $<

$(BUILD)/chassis:
	mkdir -p $(BUILD)/chassis

$(BUILD)/test_abort_resume.wasm: $(TEST_ABORT_OBJ)
	$(LD) $(LDFLAGS) -Wl,--allow-undefined -o $@ $^

test-abort-resume: $(BUILD)/test_abort_resume.wasm
	$(NODE) test_abort_resume.mjs $(BUILD)/test_abort_resume.wasm

.PHONY: test-abort-resume
