{
  "$comment": "Sensor catalog for wasm-dist HardwareSimulator. Auto-generation planned via scraper.",
  "version": "0.2.0",
  "sensors": {
    "bme280": {
      "name": "BME280",
      "description": "Temperature, humidity, pressure sensor",
      "library": "adafruit_bme280",
      "bus": "i2c",
      "addresses": [119, 118],
      "chip_id": { "register": 208, "value": 96 },
      "protocol": "register",
      "sensor_type": "bme280",
      "capabilities": {
        "temperature": { "unit": "C", "range": [-40, 85], "default": 22.5, "precision": 2 },
        "humidity":    { "unit": "%", "range": [0, 100],  "default": 45.0, "precision": 1 },
        "pressure":    { "unit": "hPa", "range": [300, 1100], "default": 1013.25, "precision": 2 }
      },
      "calibration": {
        "dig_T1": 27504, "dig_T2": 26435, "dig_T3": -1000,
        "dig_P1": 36477, "dig_P2": -10685, "dig_P3": 3024,
        "dig_P4": 2855, "dig_P5": 140, "dig_P6": -7,
        "dig_P7": 15500, "dig_P8": -14600, "dig_P9": 6000,
        "dig_H1": 75, "dig_H2": 370, "dig_H3": 0,
        "dig_H4": 313, "dig_H5": 50, "dig_H6": 30
      },
      "registers": {
        "chip_id":     { "addr": 208, "size": 1, "read_only": true },
        "calib_tp":    { "addr": 136, "size": 24, "read_only": true, "$comment": "0x88: calibration T1-T3, P1-P9" },
        "calib_h1":    { "addr": 161, "size": 1, "read_only": true, "$comment": "0xA1: dig_H1" },
        "calib_h2":    { "addr": 225, "size": 7, "read_only": true, "$comment": "0xE1: dig_H2-H6" },
        "ctrl_hum":    { "addr": 242, "size": 1, "default": 1 },
        "status":      { "addr": 243, "size": 1, "default": 0 },
        "ctrl_meas":   { "addr": 244, "size": 1, "default": 39 },
        "config":      { "addr": 245, "size": 1, "default": 0 },
        "pressure":    { "addr": 247, "size": 3, "format": "uint20_be", "capability": "pressure" },
        "temperature": { "addr": 250, "size": 3, "format": "uint20_be", "capability": "temperature" },
        "humidity":    { "addr": 253, "size": 2, "format": "uint16_be", "capability": "humidity" }
      },
      "value_encoding": {
        "$comment": "BME280 uses calibration-based compensation; encoding handled by sensor_type:bme280 in SensorSimulator"
      }
    },
    "vl53l1x": {
      "name": "VL53L1X",
      "description": "Time-of-flight distance sensor",
      "library": "adafruit_vl53l1x",
      "bus": "i2c",
      "addresses": [41],
      "chip_id": { "register": 271, "value": 234 },
      "protocol": "register",
      "sensor_type": "vl53l1x",
      "capabilities": {
        "distance": { "unit": "mm", "range": [0, 4000], "default": 250, "precision": 0 }
      },
      "registers": {
        "i2c_slave_addr":   { "addr": 1,   "size": 1, "default": 41 },
        "vhv_config":       { "addr": 8,   "size": 1, "default": 0 },
        "gpio_hv_mux_ctrl": { "addr": 48,  "size": 1, "default": 17, "$comment": "0x11: bit4=1 for active-low interrupt" },
        "gpio_tio_hv_status": { "addr": 49, "size": 1, "default": 2, "$comment": "0x02: bit0=0 initially (not ready)" },
        "mode_start":       { "addr": 135, "size": 1, "default": 0 },
        "interrupt_clear":  { "addr": 134, "size": 1, "default": 0 },
        "phasecal_timeout": { "addr": 75,  "size": 1, "default": 10, "$comment": "0x0A = long distance mode" },
        "range_timeout_a":  { "addr": 94,  "size": 2, "default": 0 },
        "vcsel_period_a":   { "addr": 96,  "size": 1, "default": 15 },
        "range_timeout_b":  { "addr": 97,  "size": 2, "default": 0 },
        "vcsel_period_b":   { "addr": 99,  "size": 1, "default": 13 },
        "valid_phase_high": { "addr": 105, "size": 1, "default": 184 },
        "woi_sd0":          { "addr": 120, "size": 2, "default": 0 },
        "initial_phase_sd0":{ "addr": 122, "size": 2, "default": 0 },
        "roi_center":       { "addr": 127, "size": 1, "default": 199 },
        "roi_xy":           { "addr": 128, "size": 1, "default": 255 },
        "range_status":     { "addr": 137, "size": 17, "default": 0 },
        "distance":         { "addr": 150, "size": 2, "format": "uint16_be", "capability": "distance" },
        "model_id":         { "addr": 271, "size": 1, "read_only": true },
        "module_type":      { "addr": 272, "size": 1, "default": 204, "read_only": true },
        "mask_rev":         { "addr": 273, "size": 1, "default": 16, "read_only": true, "$comment": "0x10" }
      },
      "value_encoding": {
        "distance": { "formula": "raw", "inverse": "value" }
      }
    },
    "lis3dh": {
      "name": "LIS3DH",
      "description": "3-axis accelerometer",
      "library": "adafruit_lis3dh",
      "bus": "i2c",
      "addresses": [24, 25],
      "chip_id": { "register": 15, "value": 51 },
      "protocol": "register",
      "capabilities": {
        "acceleration": { "unit": "m/s2", "axes": ["x", "y", "z"], "range": [-78.4, 78.4], "default": [0, 0, 9.8], "precision": 2 }
      },
      "registers": {
        "who_am_i":     { "addr": 15, "size": 1, "read_only": true },
        "tempcfg":      { "addr": 31, "size": 1, "default": 0 },
        "ctrl_reg1":    { "addr": 32, "size": 1, "default": 7 },
        "ctrl_reg3":    { "addr": 34, "size": 1, "default": 0 },
        "ctrl_reg4":    { "addr": 35, "size": 1, "default": 0 },
        "ctrl_reg5":    { "addr": 36, "size": 1, "default": 0 },
        "status":       { "addr": 39, "size": 1, "default": 255, "$comment": "0xFF: all axes available + new data" },
        "out_x_l":      { "addr": 40, "size": 6, "format": "int16_le_x3", "capability": "acceleration",
                          "auto_increment": true },
        "int1_src":     { "addr": 49, "size": 1, "default": 0 },
        "click_cfg":    { "addr": 56, "size": 1, "default": 0 },
        "click_src":    { "addr": 57, "size": 1, "default": 0 },
        "click_ths":    { "addr": 58, "size": 1, "default": 0 },
        "time_limit":   { "addr": 59, "size": 1, "default": 0 },
        "time_latency": { "addr": 60, "size": 1, "default": 0 },
        "time_window":  { "addr": 61, "size": 1, "default": 0 }
      },
      "value_encoding": {
        "acceleration": {
          "comment": "6 bytes: XL,XH,YL,YH,ZL,ZH as int16_le, scaled by range/32768 * 9.806",
          "formula": "raw_i16 / 16384.0 * 9.806",
          "inverse": "value / 9.806 * 16384.0"
        }
      }
    },
    "sht31d": {
      "name": "SHT31-D",
      "description": "Temperature and humidity sensor",
      "library": "adafruit_sht31d",
      "bus": "i2c",
      "addresses": [68, 69],
      "chip_id": null,
      "protocol": "command",
      "sensor_type": "sht31d",
      "capabilities": {
        "temperature": { "unit": "C", "range": [-40, 125], "default": 22.5, "precision": 2 },
        "humidity":    { "unit": "%", "range": [0, 100],  "default": 45.0, "precision": 1 }
      },
      "commands": {
        "measure_high":       { "cmd": [36, 0],   "response_size": 6, "delay_ms": 15, "response_format": "sht3x_temp_hum" },
        "measure_med":        { "cmd": [36, 11],  "response_size": 6, "delay_ms": 6,  "response_format": "sht3x_temp_hum" },
        "measure_low":        { "cmd": [36, 22],  "response_size": 6, "delay_ms": 4,  "response_format": "sht3x_temp_hum" },
        "measure_high_cs":    { "cmd": [44, 6],   "response_size": 6, "delay_ms": 15, "response_format": "sht3x_temp_hum" },
        "measure_med_cs":     { "cmd": [44, 13],  "response_size": 6, "delay_ms": 6,  "response_format": "sht3x_temp_hum" },
        "measure_low_cs":     { "cmd": [44, 16],  "response_size": 6, "delay_ms": 4,  "response_format": "sht3x_temp_hum" },
        "status":             { "cmd": [243, 45], "response_size": 3, "response_format": "sht3x_status" },
        "clear_status":       { "cmd": [48, 65],  "response_size": 0 },
        "reset":              { "cmd": [48, 162], "response_size": 0 },
        "heater_on":          { "cmd": [48, 109], "response_size": 0 },
        "heater_off":         { "cmd": [48, 102], "response_size": 0 },
        "periodic_break":     { "cmd": [48, 147], "response_size": 0 },
        "serial_number":      { "cmd": [55, 128], "response_size": 6, "response_format": "sht3x_serial" },
        "periodic_fetch":     { "cmd": [224, 0],  "response_size": 6, "response_format": "sht3x_temp_hum" }
      },
      "value_encoding": {
        "temperature": { "formula": "-45 + 175 * (raw / 65535.0)", "inverse": "(value + 45) / 175.0 * 65535.0" },
        "humidity":    { "formula": "100 * (raw / 65535.0)", "inverse": "value / 100.0 * 65535.0" }
      }
    }
  }
}
